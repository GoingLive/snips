<ui:FluentWindow x:Class="Snips.App.InteractivePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource Str_AppName}" SizeToContent="Height" Width="380" MinHeight="140"
        Background="#FFFBEA"
        WindowBackdropType="None" WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        KeyDown="Window_KeyDown">
    <!-- Fields are built dynamically in code-behind — one form per SPEC.md §7.6, however
         many interactive placeholders the snippet contains. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Same title-inset fix as MainWindow/SnippetEditWindow — the Title shorthand renders
             with no left inset; this window had been missed when the others were fixed. -->
        <ui:TitleBar Grid.Row="0" ShowMaximize="False" ShowMinimize="False">
            <ui:TitleBar.Header>
                <TextBlock Text="{DynamicResource Str_AppName}" FontSize="16" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" MaxHeight="420" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="FieldsPanel"/>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <ui:Button x:Name="CancelButton" Content="{DynamicResource Str_Cancel}" Appearance="Secondary" Width="80" Margin="0,0,8,0" Click="CancelButton_Click"/>
                <ui:Button x:Name="OkButton" Content="{DynamicResource Str_OkButton}" Appearance="Primary" Width="80" IsDefault="True" Click="OkButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
