<ui:FluentWindow x:Class="Snips.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Snips" Height="600" Width="420" MinHeight="400" MinWidth="320"
        Icon="Resources/tray.ico"
        Background="#FFFBEA"
        WindowBackdropType="None"
        WindowCornerPreference="Round"
        ShowInTaskbar="True"
        Closing="MainWindow_Closing"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="Accent" Color="#E0A800"/>
        <!-- Roland's contrast fix: orange is a highlight, not a reading surface — rows are
             white with deep-brown text, orange is reserved for the dividing lines. -->
        <SolidColorBrush x:Key="Surface" Color="White"/>
        <SolidColorBrush x:Key="RowDivider" Color="#E67300"/>
        <SolidColorBrush x:Key="TextOnSurface" Color="#3E2A15"/>
        <SolidColorBrush x:Key="TextOnSurfaceMuted" Color="#8A6B4A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B6355"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <tb:TaskbarIcon x:Name="TrayIcon"
                         IconSource="Resources/tray.ico"
                         ToolTipText="Snips"
                         TrayLeftMouseDoubleClick="TrayIcon_TrayLeftMouseDoubleClick"
                         TrayLeftMouseUp="TrayIcon_TrayLeftMouseUp">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show Snips" Click="ShowMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="Quit" Click="QuitMenuItem_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Draggable strip — FluentWindow suppresses the native title bar, so this is what
                 makes the window movable. Title text is left blank here; the real heading below
                 (left-aligned to match every other label) is what's actually meant to be read. -->
            <ui:TitleBar Grid.Row="0" Title="" ShowMaximize="False"/>

            <StackPanel Grid.Row="1" Margin="16,0,16,10">
                <TextBlock Text="Snips" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="The tool to define and paste snippets at your fingertips."
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource TextSecondary}"
                           TextWrapping="Wrap" Margin="0,2,0,0"/>
            </StackPanel>

            <Grid Grid.Row="2" Margin="16,0,16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Search + quick add -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" Grid.Column="0" Padding="6,4"
                             FontSize="14"
                             TextChanged="SearchBox_TextChanged"
                             PreviewKeyDown="SearchBox_PreviewKeyDown"/>
                    <ui:Button x:Name="NewSnippetButton" Grid.Column="1" Content="New" Appearance="Primary"
                               Margin="8,0,0,0" Click="NewSnippetButton_Click"/>
                </Grid>

                <!-- Results -->
                <ListBox x:Name="ResultsList" Grid.Row="1" Margin="0,0,0,8" Padding="0,0,6,0"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="ResultsList_SelectionChanged"
                         MouseDoubleClick="ResultsList_MouseDoubleClick"
                         KeyDown="ResultsList_KeyDown"
                         PreviewMouseRightButtonDown="ResultsList_PreviewMouseRightButtonDown">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="New" Click="NewMenuItem_Click"/>
                            <MenuItem Header="Edit" Click="EditMenuItem_Click"/>
                            <MenuItem Header="Duplicate" Click="DuplicateMenuItem_Click"/>
                            <MenuItem Header="Delete" Click="DeleteMenuItem_Click"/>
                            <Separator/>
                            <MenuItem Header="Define a shortcut…" Click="DefineShortcutMenuItem_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,2"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <!-- Selection is driven by DataTemplate.Triggers against named elements here,
                             not the ListBoxItem's own Background — WPF-UI's Fluent template doesn't
                             visibly react to that property being set from an external style, so an
                             ItemContainerStyle trigger was silently a no-op. This approach owns every
                             pixel directly and can't be defeated by the base control template. -->
                        <DataTemplate>
                            <Border x:Name="RowBorder" Background="{StaticResource Surface}"
                                    BorderBrush="{StaticResource RowDivider}" BorderThickness="0,0,0,1">
                                <Grid Margin="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="NameText" Text="{Binding Snippet.Name}" Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   Foreground="{StaticResource TextOnSurface}"/>
                                        <TextBlock x:Name="DescriptionText" Text="{Binding Snippet.Description}" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{StaticResource TextOnSurfaceMuted}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock x:Name="ShortcutText" Grid.Column="1" Text="{Binding ShortcutLabel}" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{StaticResource TextOnSurfaceMuted}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                    <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource Accent}"/>
                                    <Setter TargetName="NameText" Property="Foreground" Value="White"/>
                                    <Setter TargetName="DescriptionText" Property="Foreground" Value="#FFF3D6"/>
                                    <Setter TargetName="ShortcutText" Property="Foreground" Value="#FFF3D6"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="2" Text="Preview" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,4"/>

                <!-- Preview / result field -->
                <TextBox x:Name="PreviewBox" Grid.Row="3" Margin="0,0,0,8"
                         IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Background="White"/>

                <!-- Output options -->
                <StackPanel Grid.Row="4">
                    <!-- Roland's call: not worth a third checkbox (three didn't fit the window's
                         width on one row anyway, so it was likely being silently clipped) —
                         Ctrl+Enter covers the "keep it open" case for anyone who wants it. -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <CheckBox x:Name="CopyCheckBox" Content="Copy to clipboard" IsChecked="True" Margin="0,0,16,0"/>
                        <CheckBox x:Name="PasteCheckBox" Content="Paste into active app" IsChecked="False"/>
                    </StackPanel>
                    <TextBlock x:Name="StatusText" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="© 2026 Roland Hüttmann" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
                        <TextBlock x:Name="BuildInfoText" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap" Cursor="Hand"
                                   ToolTip="Click to copy this build identifier"
                                   MouseLeftButtonDown="BuildInfoText_MouseLeftButtonDown"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
