<ui:FluentWindow x:Class="Snips.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Snips" Height="640" Width="420" MinHeight="460" MinWidth="320"
        Icon="Resources/tray.ico"
        Background="#FFFBEA"
        WindowBackdropType="None"
        WindowCornerPreference="Round"
        ShowInTaskbar="True"
        Closing="MainWindow_Closing"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="Accent" Color="#E0A800"/>
        <!-- Roland's contrast fix: orange is a highlight, not a reading surface — rows are
             white with deep-brown text, orange is reserved for the dividing lines. -->
        <SolidColorBrush x:Key="Surface" Color="White"/>
        <SolidColorBrush x:Key="RowDivider" Color="#E67300"/>
        <SolidColorBrush x:Key="TextOnSurface" Color="#3E2A15"/>
        <SolidColorBrush x:Key="TextOnSurfaceMuted" Color="#8A6B4A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B6355"/>

        <!-- ui:TextBox's built-in clear ("X") button reads these theme keys via DynamicResource
             from inside its own control template (confirmed against WPF-UI's TextBox.xaml
             source). Declared here rather than overridden app-wide, so only controls within
             THIS window pick up the warm recolor — this window has no other control that reads
             these particular "Subtle" keys today, but a future one added here would. -->
        <SolidColorBrush x:Key="TextControlButtonForeground" Color="#E0A800"/>
        <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="#FFF3D6"/>
        <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="#FFE9B3"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <tb:TaskbarIcon x:Name="TrayIcon"
                         IconSource="Resources/tray.ico"
                         ToolTipText="Snips"
                         TrayLeftMouseDoubleClick="TrayIcon_TrayLeftMouseDoubleClick"
                         TrayLeftMouseUp="TrayIcon_TrayLeftMouseUp">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show Snips" Click="ShowMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="Quit" Click="QuitMenuItem_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Draggable strip — FluentWindow suppresses the native title bar, so this is what
                 makes the window movable. Using Header (not the Title shorthand property) is
                 deliberate: checked against WPF-UI's TitleBar.xaml source, the Title-driven text
                 renders with NO left inset at all — only the (empty, icon-less) column next to it
                 gets the 16px Padding-driven margin. Title rendered flush against the window's
                 left edge, not aligned with the subtitle/content below it. An explicit Header
                 with its own 16px margin guarantees it lines up with everything else instead of
                 relying on a template quirk that doesn't actually apply to it. -->
            <ui:TitleBar Grid.Row="0" ShowMaximize="False" ShowHelp="True" HelpClicked="TitleBar_HelpClicked">
                <ui:TitleBar.Header>
                    <TextBlock Text="Snips" FontSize="16" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center"/>
                </ui:TitleBar.Header>
            </ui:TitleBar>

            <TextBlock Grid.Row="1" Text="The tool to define and paste snippets at your fingertips."
                       Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource TextSecondary}"
                       TextWrapping="Wrap" Margin="16,0,16,6"/>

            <Grid Grid.Row="2" Margin="16,0,16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Search + favorites-only filter + sort mode + quick add. Favorites still pin
                     to the top of the full list by default (Roland's redesign, 2026-07-24) — the
                     filter toggle below is an ADDITIONAL, separate way to see just favorites with
                     nothing else, per his follow-up ("the filter only for favorites is still
                     valid"). Deliberately NOT persisted to Settings this time, unlike the other
                     checkboxes — a stuck-on persisted filter that silently hides everything is
                     exactly the bug that prompted removing the first version of this control. -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="SearchBox" Grid.Column="0" Padding="6,4"
                             FontSize="14" PlaceholderText="Search snippets…" ClearButtonEnabled="True"
                             TextChanged="SearchBox_TextChanged"
                             PreviewKeyDown="SearchBox_PreviewKeyDown"/>
                    <ToggleButton x:Name="FavoritesFilterToggle" Grid.Column="1" Margin="8,0,0,0"
                                  ToolTip="Show only favorites" Checked="FavoritesFilterToggle_Changed"
                                  Unchecked="FavoritesFilterToggle_Changed">
                        <ui:SymbolIcon Symbol="Star24" Filled="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                    </ToggleButton>
                    <!-- Only orders the non-favorite part of the list — favorites always keep
                         their own drag order regardless of this. Persisted, unlike the toggle
                         above: a remembered sort preference can't hide anything, so it doesn't
                         carry the same risk. -->
                    <ComboBox x:Name="SortModeComboBox" Grid.Column="2" Margin="8,0,0,0" Width="90"
                              ToolTip="Sort the rest of the list" SelectionChanged="SortModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="A-Z" Tag="Name"/>
                        <ComboBoxItem Content="Newest" Tag="Recent"/>
                    </ComboBox>
                    <ui:Button x:Name="NewSnippetButton" Grid.Column="3" Content="New" Appearance="Primary"
                               Margin="8,0,0,0" Click="NewSnippetButton_Click"/>
                </Grid>

                <!-- Results. NOTE: ListBox.Padding is deliberately NOT set here — checked
                     against WPF-UI's own ListBox.xaml source and it's never consumed by that
                     control's template (PART_ContentHost has no Padding template-binding), so
                     it silently does nothing. The real fix for scrollbar/content overlap has
                     to live in the row template below instead. -->
                <!-- AllowDrop/drag handlers only do anything for a favorite row being dragged
                     onto another favorite row (checked in code) — reordering only makes sense
                     within the favorites section, whether that's the top of the full list or the
                     favorites-only filtered view. -->
                <!-- ScrollViewer.HorizontalScrollBarVisibility="Disabled" overrides WPF-UI's
                     default of "Auto" for this. Root cause finally traced with real evidence
                     (a screenshot, not a guess): "Auto" makes the internal ScrollViewer measure
                     row content with effectively infinite width, so TextTrimming never had
                     anything to trim against, and NameText (which never had TextTrimming set at
                     all, unlike DescriptionText) could push a row wider than the viewport for
                     any long snippet name — triggering a horizontal scrollbar, which then also
                     broke the vertical-scrollbar clearance margin below, since the row's real
                     content no longer matched what that margin was measured against. Disabling
                     it forces proper width-constrained measurement, which is what makes
                     TextTrimming (added to NameText below) actually take effect. -->
                <ListBox x:Name="ResultsList" Grid.Row="1" Margin="0,0,0,8"
                         Background="Transparent" BorderThickness="0" AllowDrop="True"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="ResultsList_SelectionChanged"
                         MouseDoubleClick="ResultsList_MouseDoubleClick"
                         KeyDown="ResultsList_KeyDown"
                         PreviewMouseRightButtonDown="ResultsList_PreviewMouseRightButtonDown"
                         PreviewMouseLeftButtonDown="ResultsList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="ResultsList_PreviewMouseMove"
                         DragOver="ResultsList_DragOver"
                         Drop="ResultsList_Drop">
                    <ListBox.ContextMenu>
                        <ContextMenu Opened="ResultsListContextMenu_Opened">
                            <MenuItem Header="New" Click="NewMenuItem_Click"/>
                            <MenuItem Header="Edit" Click="EditMenuItem_Click"/>
                            <MenuItem Header="Duplicate" Click="DuplicateMenuItem_Click"/>
                            <MenuItem Header="Delete" Click="DeleteMenuItem_Click"/>
                            <Separator/>
                            <!-- Only shown when the right-clicked row is itself a favorite —
                                 see ResultsListContextMenu_Opened. -->
                            <MenuItem x:Name="MoveUpMenuItem" Header="Move Up" Click="MoveUpMenuItem_Click"/>
                            <MenuItem x:Name="MoveDownMenuItem" Header="Move Down" Click="MoveDownMenuItem_Click"/>
                            <Separator x:Name="MoveSeparator"/>
                            <MenuItem Header="Define a shortcut…" Click="DefineShortcutMenuItem_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,2"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <!-- Selection is driven by DataTemplate.Triggers against named elements here,
                             not the ListBoxItem's own Background — WPF-UI's Fluent template doesn't
                             visibly react to that property being set from an external style, so an
                             ItemContainerStyle trigger was silently a no-op. This approach owns every
                             pixel directly and can't be defeated by the base control template. -->
                        <DataTemplate>
                            <!-- Right margin (16px) clears WPF-UI's vertical scrollbar, which is
                                 confirmed (from WPF-UI's ScrollBar.xaml/ScrollViewer.xaml source)
                                 to be 14px wide and to sit ON TOP of the content column rather
                                 than being reserved space next to it — the ScrollViewer's content
                                 presenter is deliberately Grid.ColumnSpan="2", spanning under the
                                 scrollbar's own column. Nothing at the ListBox level can fix that
                                 (see the ListBox.Padding note above), so each row reserves its own
                                 clearance instead. -->
                            <Border x:Name="RowBorder" Background="{StaticResource Surface}"
                                    BorderBrush="{StaticResource RowDivider}" BorderThickness="0,0,0,1"
                                    Margin="0,0,16,0">
                                <Grid Margin="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Drag handle — only a favorite is reorderable, so only
                                         favorite rows get one. Roland's own question: "we need
                                         to show a drag button... or not?" — yes, a hidden
                                         "anywhere on the row" drag target isn't discoverable. -->
                                    <ui:SymbolIcon x:Name="DragHandleIcon" Grid.Column="0" Symbol="ReOrderDotsVertical24" FontSize="15"
                                                   Foreground="{StaticResource TextOnSurfaceMuted}" VerticalAlignment="Center"
                                                   Margin="0,0,4,0" ToolTip="Drag to reorder favorites"
                                                   Visibility="Collapsed"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="NameText" Text="{Binding Snippet.Name}" Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   Foreground="{StaticResource TextOnSurface}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="DescriptionText" Text="{Binding Snippet.Description}" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{StaticResource TextOnSurfaceMuted}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock x:Name="ShortcutText" Grid.Column="2" Text="{Binding ShortcutLabel}" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{StaticResource TextOnSurfaceMuted}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <!-- Always-visible favorite toggle — filled star = favorite.
                                         Foreground set explicitly (not inherited) since the
                                         selection trigger below inverts everything else to white. -->
                                    <ui:Button x:Name="FavoriteRowButton" Grid.Column="3" Appearance="Transparent"
                                               Padding="4" Margin="4,0,0,0" VerticalAlignment="Center"
                                               ToolTip="Toggle favorite" Click="FavoriteRowButton_Click">
                                        <ui:SymbolIcon x:Name="FavoriteIcon" Symbol="Star24" FontSize="15"
                                                       Filled="{Binding Snippet.IsFavorite}" Foreground="{StaticResource Accent}"/>
                                    </ui:Button>
                                    <!-- Always-visible edit affordance — double-click still opens
                                         the editor too, but per Roland's ask that's a shortcut on
                                         top of this, not the only way to find it. -->
                                    <ui:Button x:Name="EditRowButton" Grid.Column="4" Appearance="Transparent"
                                               Padding="4" Margin="4,0,0,0" VerticalAlignment="Center"
                                               ToolTip="Edit this snippet" Click="EditRowButton_Click">
                                        <ui:SymbolIcon Symbol="Edit24" FontSize="15"/>
                                    </ui:Button>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                    <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource Accent}"/>
                                    <Setter TargetName="NameText" Property="Foreground" Value="White"/>
                                    <Setter TargetName="DescriptionText" Property="Foreground" Value="#FFF3D6"/>
                                    <Setter TargetName="ShortcutText" Property="Foreground" Value="#FFF3D6"/>
                                    <Setter TargetName="EditRowButton" Property="Foreground" Value="White"/>
                                    <!-- Fixed accent-orange star would nearly vanish against the
                                         same-colored selected-row background — switch to white
                                         (still filled/outline-distinct) like everything else here. -->
                                    <Setter TargetName="FavoriteIcon" Property="Foreground" Value="White"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Snippet.IsFavorite}" Value="True">
                                    <Setter TargetName="DragHandleIcon" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <!-- Marks the boundary between the favorites section and the rest
                                     of the (alphabetical) list — a thicker accent-colored bottom
                                     border on the LAST favorite row, per Roland's "visually a bit
                                     separated" ask. Only ever set when the search box is empty
                                     (see ApplyFilter) since that's the only time this pinned
                                     ordering is in effect at all. -->
                                <DataTrigger Binding="{Binding IsLastFavoriteBeforeRest}" Value="True">
                                    <Setter TargetName="RowBorder" Property="BorderThickness" Value="0,0,0,3"/>
                                    <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="2" Text="Preview" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,4"/>

                <!-- Preview / result field. Unlike ListBox, plain TextBox's own Padding IS
                     correctly template-bound (confirmed in WPF-UI's TextBox.xaml — it becomes
                     the Margin around the internal scroll host), so 18px here genuinely clears
                     the confirmed 14px-wide scrollbar with room to spare. MinHeight guarantees
                     6-7 lines stay visible without scrolling regardless of how the 2*/1* split
                     with the results list above works out at any given window size. -->
                <TextBox x:Name="PreviewBox" Grid.Row="3" Margin="0,0,0,8" Padding="8,6,18,6" MinHeight="150"
                         IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Background="White"/>

                <!-- Output options. Every behavior here is a visible, always-on-screen checkbox
                     now — no hidden keyboard modifiers, no "tip" text explaining a shortcut
                     nobody would otherwise discover (Roland's explicit UX ask). ToolTips are
                     kept to one short sentence each. -->
                <StackPanel Grid.Row="4" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <CheckBox x:Name="CopyCheckBox" Content="Copy to clipboard" IsChecked="True" Margin="0,0,16,0"
                                  Checked="CopyCheckBox_Changed" Unchecked="CopyCheckBox_Changed"
                                  ToolTip="Copies the result to your clipboard."/>
                        <CheckBox x:Name="PasteCheckBox" Content="Paste into active app" IsChecked="False"
                                  Checked="PasteCheckBox_Changed" Unchecked="PasteCheckBox_Changed"
                                  ToolTip="Also types the result into the app you had open before Snips."/>
                    </StackPanel>
                    <CheckBox x:Name="CloseAfterApplyCheckBox" Content="Close this window after applying" IsChecked="False"
                              Margin="0,0,0,4" Checked="CloseAfterApplyCheckBox_Changed" Unchecked="CloseAfterApplyCheckBox_Changed"
                              ToolTip="If off, the window stays open so you can apply another snippet."/>
                    <TextBlock x:Name="StatusText" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="© 2026 Roland Hüttmann" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
                        <TextBlock x:Name="BuildInfoText" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap" Cursor="Hand"
                                   ToolTip="Click to copy this build identifier"
                                   MouseLeftButtonDown="BuildInfoText_MouseLeftButtonDown"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
