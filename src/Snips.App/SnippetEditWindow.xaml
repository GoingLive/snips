<ui:FluentWindow x:Class="Snips.App.SnippetEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource Str_EditorTitle}" Height="500" Width="700" MinWidth="560" MinHeight="420"
        Background="#FFFBEA"
        WindowBackdropType="None" WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <!--
        Plain-text editor only. The rich-text WebView2 editor from SPEC.md §5.7 is Phase 3;
        this exists so Phase 2's picker has a real way to create and edit snippets meanwhile.
    -->
    <ui:FluentWindow.Resources>
        <!-- Same warm recolor for ui:TextBox's built-in clear button as MainWindow — see that
             window's Resources for why these particular keys and why window-scoped. -->
        <SolidColorBrush x:Key="TextControlButtonForeground" Color="#E0A800"/>
        <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="#FFF3D6"/>
        <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="#FFE9B3"/>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Same fix as MainWindow's title bar: the Title shorthand renders with NO left inset
             (confirmed from WPF-UI's TitleBar.xaml source), so it sat flush against the window
             edge instead of aligned with the form below it. An explicit Header with its own
             16px margin matches. -->
        <ui:TitleBar Grid.Row="0" ShowMaximize="False" ShowMinimize="False">
            <ui:TitleBar.Header>
                <TextBlock Text="{DynamicResource Str_EditorTitle}" FontSize="16" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Form -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Str_NameLabel}" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1" x:Name="FavoriteCheckBox" Content="{DynamicResource Str_FavoriteCheckbox}" VerticalAlignment="Center"/>
                </Grid>
                <TextBox Grid.Row="1" x:Name="NameBox" Margin="0,0,0,12"/>

                <!-- Optional per-snippet shortcut (SPEC.md §5.8), Roland's ask: reachable from
                     the editor itself, not only the list's right-click menu. Persists
                     immediately through ShortcutCaptureWindow (the same dialog and repository
                     call the context menu already used and tested), independent of this
                     window's own Save/Cancel — so it needs a real snippet ID to attach to.
                     Disabled rather than hidden for a brand-new, not-yet-saved snippet (visible,
                     explained affordance over a hidden one, per Roland's own UX principle) —
                     save the snippet first, then it becomes reachable from here or the row. -->
                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Str_ShortcutLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" x:Name="ShortcutDisplayText" Text="{DynamicResource Str_None}" VerticalAlignment="Center"
                               Foreground="#8A6B4A"/>
                    <ui:Button Grid.Column="2" x:Name="AssignShortcutButton" Content="{DynamicResource Str_AssignButton}" Appearance="Secondary"
                               Padding="8,4" Margin="0,0,8,0" Click="AssignShortcutButton_Click"/>
                    <ui:Button Grid.Column="3" x:Name="ClearShortcutButton" Content="{DynamicResource Str_ClearButton}" Appearance="Secondary"
                               Padding="8,4" Click="ClearShortcutButton_Click" Visibility="Collapsed"/>
                </Grid>

                <TextBlock Grid.Row="3" Text="{DynamicResource Str_DescriptionLabel}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="4" x:Name="DescriptionBox" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="5" Text="{DynamicResource Str_BodyLabel}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="6" x:Name="BodyBox" Margin="0,0,0,12"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>

                <TextBlock Grid.Row="7" x:Name="ErrorText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="#B00020" Margin="0,0,0,8"
                           TextWrapping="Wrap" Visibility="Collapsed"/>

                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Only shown when editing an existing snippet — kept apart from Cancel/Save
                         (its own column, not the same StackPanel) so a destructive action never
                         sits directly beside the default/Enter-triggered Save button. -->
                    <ui:Button Grid.Column="0" x:Name="DeleteButton" Content="{DynamicResource Str_Delete}" Appearance="Secondary"
                               Foreground="#B00020" Click="DeleteButton_Click"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ui:Button x:Name="CancelButton" Content="{DynamicResource Str_Cancel}" Appearance="Secondary" Width="80" Margin="0,0,8,0" Click="CancelButton_Click"/>
                        <ui:Button x:Name="SaveButton" Content="{DynamicResource Str_Save}" Appearance="Primary" Width="80" IsDefault="True" Click="SaveButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Variable reference — double-click (or Enter) inserts the token at the caret.
                 Roland asked for this directly: the user had no way to know what variables
                 exist, so they were typing guesses like {{Roland}} that could never resolve. -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{DynamicResource Str_VariablesHeader}"
                           Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" Margin="0,0,0,4"/>

                <ui:TextBox Grid.Row="1" x:Name="VariableSearchBox" Padding="6,4" Margin="0,0,0,6"
                            PlaceholderText="{DynamicResource Str_VariableSearchPlaceholder}" ClearButtonEnabled="True"
                            TextChanged="VariableSearchBox_TextChanged"/>

                <ListBox Grid.Row="2" x:Name="VariableReferenceList" BorderThickness="1" BorderBrush="#E0A800"
                         Background="White" MouseDoubleClick="VariableReferenceList_MouseDoubleClick"
                         KeyDown="VariableReferenceList_KeyDown">
                    <!-- WPF-UI's default ListBoxItem style pads every item 12px on all sides
                         (checked against ListBoxItem.xaml source) — that, not the item template's
                         own margin below, was the real source of the "lots of space between
                         entries" Roland flagged. Cut here since it's the actual dominant term. -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="6,2"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Right margin clears the vertical scrollbar for the same reason as
                                 MainWindow's results list — see that file's ItemTemplate comment. -->
                            <StackPanel Margin="2,2,16,2">
                                <TextBlock Text="{Binding Token}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionTextBlockStyle}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
