<ui:FluentWindow x:Class="Snips.App.SnippetEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Snippet" Height="500" Width="700" MinWidth="560" MinHeight="420"
        Background="#FFFBEA"
        WindowBackdropType="None" WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <!--
        Plain-text editor only. The rich-text WebView2 editor from SPEC.md §5.7 is Phase 3;
        this exists so Phase 2's picker has a real way to create and edit snippets meanwhile.
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Snippet" ShowMaximize="False" ShowMinimize="False"/>

        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Form -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Name" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="1" x:Name="NameBox" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="2" Text="Description" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="3" x:Name="DescriptionBox" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="4" Text="Body (plain text)" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="5" x:Name="BodyBox" Margin="0,0,0,12"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>

                <TextBlock Grid.Row="6" x:Name="ErrorText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="#B00020" Margin="0,0,0,8"
                           TextWrapping="Wrap" Visibility="Collapsed"/>

                <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button x:Name="CancelButton" Content="Cancel" Appearance="Secondary" Width="80" Margin="0,0,8,0" Click="CancelButton_Click"/>
                    <ui:Button x:Name="SaveButton" Content="Save" Appearance="Primary" Width="80" IsDefault="True" Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Variable reference — double-click (or Enter) inserts the token at the caret.
                 Roland asked for this directly: the user had no way to know what variables
                 exist, so they were typing guesses like {{Roland}} that could never resolve. -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Variables (double-click to insert)"
                           Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" Margin="0,0,0,4"/>

                <ListBox Grid.Row="1" x:Name="VariableReferenceList" BorderThickness="1" BorderBrush="#E0A800"
                         Background="White" MouseDoubleClick="VariableReferenceList_MouseDoubleClick"
                         KeyDown="VariableReferenceList_KeyDown">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,3">
                                <TextBlock Text="{Binding Token}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionTextBlockStyle}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
