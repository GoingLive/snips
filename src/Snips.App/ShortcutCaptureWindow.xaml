<Window x:Class="Snips.App.ShortcutCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snips" SizeToContent="Height" Width="360"
        Background="#FFFBEA" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Grid.Row="0" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <Border Grid.Row="1" Background="White" BorderBrush="#E0A800" BorderThickness="1"
                Padding="12" Margin="0,0,0,4">
            <TextBlock x:Name="CapturedText" Text="Press a key combination…"
                       FontSize="16" HorizontalAlignment="Center"/>
        </Border>

        <TextBlock Grid.Row="2" x:Name="ErrorText" Foreground="#B00020" TextWrapping="Wrap"
                   Margin="0,4,0,8" Visibility="Collapsed"/>

        <TextBlock Grid.Row="3" Text="Requires at least one modifier (Ctrl/Alt/Shift/Win), or a bare F1–F24 key. Esc cancels."
                   Foreground="#6B6355" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ClearButton" Content="Clear shortcut" Width="100" Margin="0,0,8,0" Click="ClearButton_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="Save" Width="80" IsEnabled="False" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
