<ui:FluentWindow x:Class="Snips.App.ShortcutCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource Str_AppName}" SizeToContent="Height" Width="360"
        Background="#FFFBEA"
        WindowBackdropType="None" WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Same title-inset fix as MainWindow/SnippetEditWindow — see either for why the
             Title shorthand doesn't work. -->
        <ui:TitleBar Grid.Row="0" ShowMaximize="False" ShowMinimize="False">
            <ui:TitleBar.Header>
                <TextBlock Text="{DynamicResource Str_AppName}" FontSize="16" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText" Grid.Row="0" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <Border Grid.Row="1" Background="White" BorderBrush="#E0A800" BorderThickness="1"
                    CornerRadius="4" Padding="12" Margin="0,0,0,4">
                <TextBlock x:Name="CapturedText" Text="{DynamicResource Str_PressCombo}"
                           FontSize="16" HorizontalAlignment="Center"/>
            </Border>

            <TextBlock Grid.Row="2" x:Name="ErrorText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="#B00020" TextWrapping="Wrap"
                       Margin="0,4,0,8" Visibility="Collapsed"/>

            <!-- Advisory, not blocking — unlike ErrorText this never disables Save. Ctrl+Alt is
                 what a physical AltGr key actually sends on most non-US keyboard layouts
                 (German/French/Italian/Spanish included), and on many of those the same
                 combination is already bound to typing a character (e.g. Swiss German AltGr+2
                 types '@'). Whether it's actually a problem depends on the user's own keyboard
                 layout, which Snips has no way to know — so this can only warn, not block. -->
            <TextBlock Grid.Row="3" x:Name="WarningText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="#8A6B00" TextWrapping="Wrap"
                       Margin="0,4,0,8" Visibility="Collapsed"
                       Text="{DynamicResource Str_AltGrWarning}"/>

            <TextBlock Grid.Row="4" Text="{DynamicResource Str_ShortcutInstructions}"
                       Style="{StaticResource CaptionTextBlockStyle}" Foreground="#6B6355" TextWrapping="Wrap" Margin="0,0,0,12"/>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="ClearButton" Content="{DynamicResource Str_ClearShortcutButton}" Appearance="Secondary" Width="100" Margin="0,0,8,0" Click="ClearButton_Click"/>
                <ui:Button x:Name="CancelButton" Content="{DynamicResource Str_Cancel}" Appearance="Secondary" Width="80" Margin="0,0,8,0" Click="CancelButton_Click"/>
                <ui:Button x:Name="SaveButton" Content="{DynamicResource Str_Save}" Appearance="Primary" Width="80" IsEnabled="False" Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
