<ui:FluentWindow x:Class="Snips.App.TranslationEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Manage Translations" Height="600" Width="720" MinWidth="560" MinHeight="420"
        Background="#FFFBEA"
        WindowBackdropType="None" WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <!-- Language-pack Phase 1 admin tool — see docs/language-pack-brief.md. One row per
         BuiltInVariableCatalog entry; LocalName is what a snippet author would type instead of
         the English MasterKey. Untranslated rows are highlighted so coverage is visible at a
         glance, per Roland's ask for a tool that shows what still needs attention. -->
    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="TextControlButtonForeground" Color="#E0A800"/>
        <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="#FFF3D6"/>
        <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="#FFE9B3"/>
        <SolidColorBrush x:Key="MissingRowBackground" Color="#FFF3D6"/>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" ShowMaximize="False">
            <ui:TitleBar.Header>
                <TextBlock Text="Manage Translations" FontSize="16" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Language:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" x:Name="LanguageComboBox" HorizontalAlignment="Left" Width="220"
                          DisplayMemberPath="DisplayName" SelectionChanged="LanguageComboBox_SelectionChanged"/>
            </Grid>

            <ui:TextBox Grid.Row="1" x:Name="SearchBox" Padding="6,4" Margin="0,0,0,8"
                        PlaceholderText="Search variables…" ClearButtonEnabled="True"
                        TextChanged="SearchBox_TextChanged"/>

            <DataGrid Grid.Row="2" x:Name="TranslationGrid" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      RowHeight="32" Background="White" BorderBrush="#E0A800" BorderThickness="1">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasTranslation}" Value="False">
                                <Setter Property="Background" Value="{StaticResource MissingRowBackground}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="English (master)" Binding="{Binding MasterKey}" IsReadOnly="True" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="4,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Meaning" Binding="{Binding Description}" IsReadOnly="True" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="Margin" Value="4,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Translated name" Binding="{Binding LocalName, UpdateSourceTrigger=PropertyChanged}" Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="4,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="3" x:Name="CoverageText" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="#6B6355" Margin="0,8,0,0"/>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <ui:Button x:Name="CloseButton" Content="Close" Appearance="Secondary" Width="80" Margin="0,0,8,0" Click="CloseButton_Click"/>
                <ui:Button x:Name="SaveButton" Content="Save" Appearance="Primary" Width="80" Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
