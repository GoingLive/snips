                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <!-- German (Swiss orthography — no ß, "ss" throughout, matching Roland's own usage). "Snippet"
         is translated as "Textbaustein" (plural "Textbausteine") throughout — the standard German
         term for a reusable text block, matching Microsoft Outlook's own terminology for the same
         concept, rather than a borrowed English word. -->
