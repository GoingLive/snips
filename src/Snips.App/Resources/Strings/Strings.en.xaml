    <system:String x:Key="Str_Example_Multiline">Prompts for multi-line text</system:String>
    <system:String x:Key="Str_Example_Choice">Prompts to pick one of the listed options</system:String>
    <system:String x:Key="Str_Example_Datepick">Prompts to pick a date</system:String>
    <system:String x:Key="Str_Example_Check">Prompts for a checkbox</system:String>
    <system:String x:Key="Str_Example_FilterChain">Filters chain with | — this uppercases the clipboard text</system:String>

    <!-- SettingsWindow -->
    <system:String x:Key="Str_SettingsTitle">Snips Settings</system:String>
    <system:String x:Key="Str_SettingsHeader">Settings</system:String>
    <system:String x:Key="Str_EmailLabel">Your email</system:String>
    <system:String x:Key="Str_EmailCaption">Used by {{useremail}} in snippets.</system:String>
    <system:String x:Key="Str_LanguageLabel">Language</system:String>
    <system:String x:Key="Str_LanguageCaption">Sets the app's own interface language, and which language's variable names Snips understands, e.g. German {{heute}} for {{date}}.</system:String>
