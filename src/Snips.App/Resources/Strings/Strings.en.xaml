    <system:String x:Key="Str_SortTooltip">Sort the rest of the list</system:String>
    <system:String x:Key="Str_SortAZ">A-Z</system:String>
    <system:String x:Key="Str_SortNewest">Newest</system:String>
    <system:String x:Key="Str_NewButton">New</system:String>
    <system:String x:Key="Str_MenuNew">New</system:String>
    <system:String x:Key="Str_MenuEdit">Edit</system:String>
    <system:String x:Key="Str_MenuDuplicate">Duplicate</system:String>
    <system:String x:Key="Str_MenuMoveUp">Move Up</system:String>
    <system:String x:Key="Str_MenuMoveDown">Move Down</system:String>
    <system:String x:Key="Str_MenuDefineShortcut">Define a shortcut…</system:String>
    <system:String x:Key="Str_DragHandleTooltip">Drag to reorder favorites</system:String>
    <system:String x:Key="Str_ToggleFavoriteTooltip">Toggle favorite</system:String>
    <system:String x:Key="Str_EditRowTooltip">Edit this snippet</system:String>
    <system:String x:Key="Str_PreviewLabel">Preview</system:String>
    <system:String x:Key="Str_CopyCheckbox">Copy to clipboard</system:String>
    <system:String x:Key="Str_CopyCheckboxTooltip">Copies the result to your clipboard.</system:String>
    <system:String x:Key="Str_PasteCheckbox">Paste into active app</system:String>
    <system:String x:Key="Str_PasteCheckboxTooltip">Also types the result into the app you had open before Snips.</system:String>
