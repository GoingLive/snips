    <system:String x:Key="Str_ClearShortcutButton">Clear shortcut</system:String>
    <system:String x:Key="Str_ModifierRequiredError">Add at least one modifier (Ctrl/Alt/Shift/Win), or use a bare F1–F24 key.</system:String>
    <system:String x:Key="Str_ReservedComboError">That combination is reserved by Windows and can't be used.</system:String>

    <!-- TranslationEditorWindow -->
    <system:String x:Key="Str_TranslationEditorTitle">Manage Translations</system:String>
    <system:String x:Key="Str_TranslationLanguageLabel">Language:</system:String>
    <system:String x:Key="Str_ColumnMaster">English (master)</system:String>
    <system:String x:Key="Str_ColumnMeaning">Meaning</system:String>
    <system:String x:Key="Str_ColumnTranslated">Translated name</system:String>
    <system:String x:Key="Str_CloseButton">Close</system:String>
    <system:String x:Key="Str_CoverageFormat">{0} of {1} translated.</system:String>
    <system:String x:Key="Str_SavedSuffix"> Saved.</system:String>

    <!-- InteractivePromptWindow -->
    <system:String x:Key="Str_OkButton">OK</system:String>

    <!-- App.xaml.cs — MessageBox bodies, tray tooltip -->
    <system:String x:Key="Str_UnhandledExceptionFormat">Snips hit an unexpected error and stayed open, but this snippet or action may not have worked:

{0}</system:String>
    <system:String x:Key="Str_AllHotkeysClaimedFormat">All of Snips' candidate hotkeys ({0}) are already claimed by other applications. Open Snips from the tray icon instead until a rebindable Settings view exists.</system:String>
    <system:String x:Key="Str_HotkeyFallbackNoticeFormat">Ctrl+Alt+Space is already in use by another application, so Snips bound {0} instead. Press {0} to open the picker. (This notice won't be shown again.)</system:String>
    <system:String x:Key="Str_PerSnippetHotkeyFailedFormat">These snippets have a shortcut assigned, but the combination is already in use by another application: {0}. Define a different shortcut for them from the picker's right-click menu.</system:String>
    <system:String x:Key="Str_TrayTooltipNoHotkeyFormat">Snips, {0} (no hotkey bound — open from this tray icon)</system:String>
    <system:String x:Key="Str_TrayTooltipWithHotkeyFormat">Snips, {0} — {1} to open</system:String>

