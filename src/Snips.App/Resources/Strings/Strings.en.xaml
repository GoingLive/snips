    <system:String x:Key="Str_CloseAfterApplyTooltip">If off, the window stays open so you can apply another snippet.</system:String>
    <system:String x:Key="Str_Copyright">© 2026 Roland Hüttmann</system:String>
    <system:String x:Key="Str_BuildInfoTooltip">Click to copy this build identifier</system:String>
    <system:String x:Key="Str_TrayShow">Show Snips</system:String>
    <system:String x:Key="Str_TrayQuit">Quit</system:String>
    <system:String x:Key="Str_TraySettings">Settings…</system:String>
    <system:String x:Key="Str_StatusCancelled">Cancelled.</system:String>
    <system:String x:Key="Str_StatusClipboardBusy">Couldn't write to the clipboard — it was busy. Try again.</system:String>
    <system:String x:Key="Str_StatusNoTarget">No previous window to paste into — copied to clipboard instead.</system:String>
    <system:String x:Key="Str_StatusPasted">Pasted.</system:String>
    <system:String x:Key="Str_StatusForegroundDenied">Couldn't bring the target app to the front (Windows refused the switch) — copied to clipboard, press Ctrl+V yourself.</system:String>
    <system:String x:Key="Str_StatusFocusTimeout">Couldn't bring the target app to the front in time — copied to clipboard, press Ctrl+V yourself.</system:String>
    <system:String x:Key="Str_StatusTargetGone">Target window is gone — copied to clipboard instead.</system:String>
    <system:String x:Key="Str_StatusInputRejected">Windows rejected the paste keystrokes — copied to clipboard, press Ctrl+V yourself.</system:String>
    <system:String x:Key="Str_StatusCopied">Copied to clipboard.</system:String>
