<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <!--
        English is the master copy — every key here MUST also exist in every other Strings.*.xaml
        (UiStrings.Get falls back to this dictionary if the active language's copy is missing a
        key, so a translation can lag behind a new English string without anything breaking, but
        a key that doesn't exist HERE at all is a bug in whichever XAML/code-behind references it).
        Referenced via {DynamicResource Str_X} in XAML and UiStrings.Get("Str_X") in code-behind —
        DynamicResource (not Static) is what lets SettingsWindow swap the whole dictionary at
        runtime and have every open window's text update immediately, no restart needed.
    -->

    <!-- Common — shared across multiple windows, translated once. -->
    <system:String x:Key="Str_AppName">Snips</system:String>
    <system:String x:Key="Str_Cancel">Cancel</system:String>
    <system:String x:Key="Str_Save">Save</system:String>
    <system:String x:Key="Str_Delete">Delete</system:String>
    <system:String x:Key="Str_None">None</system:String>
    <system:String x:Key="Str_DeleteConfirmFormat">Delete '{0}'?</system:String>

    <!-- MainWindow -->
    <system:String x:Key="Str_MainSubtitle">The tool to define and paste snippets at your fingertips.</system:String>
