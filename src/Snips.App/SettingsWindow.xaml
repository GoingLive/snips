<ui:FluentWindow x:Class="Snips.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource Str_SettingsTitle}" SizeToContent="Height" Width="460"
        Background="#FFFBEA"
        WindowBackdropType="None" WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <!-- Deliberately minimal: just enough to make {{useremail}} actually usable today. The
         real Settings view (hotkey rebinding, storage location, theme, ...) is Phase 6. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Same title-inset fix as MainWindow/SnippetEditWindow — see either for why the
             Title shorthand doesn't work. -->
        <ui:TitleBar Grid.Row="0" ShowMaximize="False" ShowMinimize="False">
            <ui:TitleBar.Header>
                <TextBlock Text="{DynamicResource Str_SettingsHeader}" FontSize="16" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{DynamicResource Str_EmailLabel}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" x:Name="EmailBox" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="2" Text="{DynamicResource Str_EmailCaption}" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="#6B6355" Margin="0,0,0,16"/>

            <TextBlock Grid.Row="3" Text="{DynamicResource Str_LanguageLabel}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,4"/>
            <ComboBox Grid.Row="4" x:Name="LanguageComboBox" Margin="0,0,0,4" DisplayMemberPath="DisplayName"/>
            <TextBlock Grid.Row="5" Style="{StaticResource CaptionTextBlockStyle}" Foreground="#6B6355" Margin="0,0,0,16"
                       Text="{DynamicResource Str_LanguageCaption}"
                       TextWrapping="Wrap"/>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="0" x:Name="ManageTranslationsButton" Content="{DynamicResource Str_ManageTranslationsButton}"
                           Appearance="Secondary" Click="ManageTranslationsButton_Click"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:Button x:Name="CancelButton" Content="{DynamicResource Str_Cancel}" Appearance="Secondary" Width="80" Margin="0,0,8,0" Click="CancelButton_Click"/>
                    <ui:Button x:Name="SaveButton" Content="{DynamicResource Str_Save}" Appearance="Primary" Width="80" IsDefault="True" Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
